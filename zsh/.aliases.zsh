# .aliases.zsh - sourced from .zshrc

# Navigation
alias ~="cd ~"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Python
alias python="python3"
alias pip="pip3"

# Eza
alias ls="eza --color=always --git --icons=always --long --no-permissions --no-time --no-user"

# Thefuck
alias fk="fuck"

# Trash-cli
alias trash="trash-put"

# Zoxide
alias cd="z"
