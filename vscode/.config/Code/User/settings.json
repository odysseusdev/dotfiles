{
	"chat.tips.enabled": false,
	"claudeCode.preferredLocation": "sidebar",

	"diffEditor.codeLens": true,

	"editor.acceptSuggestionOnCommitCharacter": false,
	"editor.accessibilitySupport": "off",
	"editor.bracketPairColorization.independentColorPoolPerBracketType": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.foldingImportsByDefault": true,
	"editor.fontFamily": "'CaskaydiaCove Nerd Font Mono', Consolas, 'Courier New', monospace",
	"editor.fontLigatures": true,
	"editor.formatOnSave": true,
	"editor.formatOnType": true,
	"editor.insertSpaces": false,
	"editor.linkedEditing": true,
	"editor.parameterHints.cycle": true,
	"editor.showFoldingControls": "always",
	"editor.suggest.preview": true,
	"editor.tabCompletion": "onlySnippets",
	"editor.tabSize": 2,
	"editor.wordWrap": "on",
	"editor.wordWrapColumn": 128,
	"editor.wrappingIndent": "indent",
	"editorconfig.generateAuto": false,

	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"*.c": "${capture}, $(capture).o",
		"*.cshtml": "${capture}.cshtml.cs",
		"*.jsx": "${capture}.js, ${capture}.test.js, ${capture}.stories.jsx, ${capture}.css, ${capture}.module.css",
		"*.razor": "${capture}.razor.cs",
		"*.tsx": "${capture}.ts, ${capture}.test.tsx, ${capture}.css, ${capture}.module.css",
		"appsettings.json": "appsettings.*.json"
	},
	"explorer.incrementalNaming": "smart",
	"explorer.sortOrder": "filesFirst",

	"files.autoSave": "onFocusChange",
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,

	"git.autofetch": true,
	"git.confirmSync": false,
	"git.enableCommitSigning": true,
	"git.enableSmartCommit": true,
	"git.ignoreRebaseWarning": true,

	"html.format.indentInnerHtml": true,
	"javascript.updateImportsOnFileMove.enabled": "always",
	"json.schemaDownload.trustedDomains": {
		"https://developer.microsoft.com/json-schemas/": true,
		"https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json": true,
		"https://json-schema.org/": true,
		"https://json.schemastore.org/": true,
		"https://raw.githubusercontent.com/devcontainers/spec/": true,
		"https://raw.githubusercontent.com/microsoft/vscode/": true,
		"https://schemastore.azurewebsites.net/": true,
		"https://ui.shadcn.com": true,
		"https://www.schemastore.org/": true
	},
	"python.analysis.typeCheckingMode": "standard",
	"tailwindCSS.classFunctions": ["cva", "cx"],
	"tailwindCSS.emmetCompletions": true,
	"typescript.preferences.importModuleSpecifier": "non-relative",
	"typescript.updateImportsOnFileMove.enabled": "always",

	"prettier.arrowParens": "avoid",
	"prettier.printWidth": 128,
	"prettier.singleAttributePerLine": true,
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,

	"remote.autoForwardPortsSource": "hybrid",

	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.profiles.windows": {
		"Command Prompt": {
			"args": [],
			"icon": "terminal-cmd",
			"path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"]
		},
		"Git Bash": {
			"source": "Git Bash"
		},
		"PowerShell": {
			"icon": "terminal-powershell",
			"source": "PowerShell"
		}
	},

	"window.closeWhenEmpty": true,
	"window.commandCenter": true,
	"window.customTitleBarVisibility": "auto",
	"window.newWindowDimensions": "maximized",

	"workbench.activityBar.location": "top",
	"workbench.colorCustomizations": {
		"tree.inactiveIndentGuidesStroke": "#484843",
		"tree.indentGuidesStroke": "#64645f"
	},
	"workbench.colorTheme": "Catppuccin Macchiato",
	"workbench.editor.closeOnFileDelete": true,
	"workbench.editor.labelFormat": "short",
	"workbench.editorAssociations": {
		"*.copilotmd": "vscode.markdown.preview.editor",
		"*.svg": "imagePreview.previewEditor"
	},
	"workbench.iconTheme": "catppuccin-macchiato",
	"workbench.panel.showLabels": false,
	"workbench.startupEditor": "none",
	"workbench.tree.indent": 20,
	"workbench.tree.renderIndentGuides": "always",

	"[lua]": {
		"editor.fontLigatures": false,
		"editor.defaultFormatter": "yinfei.luahelper"
	},
	"[xml]": {
		"editor.defaultFormatter": "redhat.vscode-xml"
	}
}
