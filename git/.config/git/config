[user]
	signingkey = ~/.ssh/id_ed25519.pub
	name = odysseus
	email = mccorkell.jimmy@gmail.com
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[commit]
	gpgsign = true
[core]
	excludesfile = ~/.config/git/ignore
	autocrlf = input
[pull]
	rebase = true
[init]
	defaultBranch = main
[includeIf "gitdir:/mnt/data/work/**"]
  path = ~/.config/git/config-work